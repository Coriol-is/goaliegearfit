---
import "../styles/global.css";
import "../styles/brand.css";
import "../styles/calculator.css";
import SiteHeader from "../components/layout/SiteHeader.astro";
import SiteFooter from "../components/layout/SiteFooter.astro";
import {resolveSiteConfig} from "../lib/site-config";
import {resolveAnalyticsConfig} from "../lib/analytics";
interface Crumb {label:string;href?:string}
interface Props {title:string;description:string;canonicalPath?:string;breadcrumbs?:Crumb[]}
const {title,description,canonicalPath="/",breadcrumbs=[]}=Astro.props;
const site=resolveSiteConfig(import.meta.env.PUBLIC_SITE_ORIGIN);
const configured=site.origin;
const launchReady=site.launchReady;
const canonical=configured?new URL(canonicalPath,configured).toString():undefined;
const analytics=resolveAnalyticsConfig(import.meta.env.PUBLIC_ANALYTICS_PROVIDER,import.meta.env.PUBLIC_PLAUSIBLE_SCRIPT_SRC,import.meta.env.PUBLIC_GA_MEASUREMENT_ID);
const analyticsBootstrap=analytics.provider==="plausible"?`window.analyticsTrack=function(event){if(window.plausible)window.plausible(event.name,{props:event.props})}`:analytics.provider==="ga"?`window.dataLayer=window.dataLayer||[];window.gtag=function(){window.dataLayer.push(arguments)};window.gtag('js',new Date());window.gtag('config',${JSON.stringify(analytics.measurementId)});var names=${JSON.stringify({"Calculator Brand Selected":"calculator_brand_selected","Calculator Completed":"calculator_completed","Calculator Fail Closed":"calculator_fail_closed","Calculator Comparison Used":"calculator_comparison_used"})};window.analyticsTrack=function(event){window.gtag('event',names[event.name],event.props)}`:"";
const graph=[{"@type":"Organization","@id":"#organization",name:"Goalie Gear Fit",...(configured?{url:configured}:{})},{"@type":"WebSite","@id":"#website",name:"Goalie Gear Fit",...(configured?{url:configured}:{})},...(breadcrumbs.length?[{"@type":"BreadcrumbList",itemListElement:breadcrumbs.map((item,index)=>({"@type":"ListItem",position:index+1,name:item.label,...(item.href&&configured?{item:new URL(item.href,configured).toString()}:{})}))}]:[])];
---
<!doctype html><html lang="en"><head><meta charset="utf-8"><meta name="viewport" content="width=device-width, initial-scale=1"><meta name="robots" content={launchReady?"index,follow":"noindex"}><title>{title}</title><meta name="description" content={description}>{canonical&&<link rel="canonical" href={canonical}/>}<meta property="og:title" content={title}><meta property="og:description" content={description}>{analytics.provider!=="none"&&<script is:inline async={analytics.provider==="ga"} defer={analytics.provider==="plausible"} src={analytics.scriptSrc}></script>}{analyticsBootstrap&&<script is:inline set:html={analyticsBootstrap}/>}<script is:inline type="application/ld+json" set:html={JSON.stringify({"@context":"https://schema.org","@graph":graph})}/></head><body><SiteHeader/><main class="shell"><slot/></main><SiteFooter/></body></html>
