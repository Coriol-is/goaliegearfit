---
import BaseLayout from "../layouts/BaseLayout.astro";import Breadcrumbs from "../components/content/Breadcrumbs.astro";import dataset from "../data/sizing/goalie-leg-pads-us-v0.1.json";const breadcrumbs=[{label:"Home",href:"/"},{label:"Calculator"}];
---
<BaseLayout title="Goalie leg-pad size calculator | Goalie Gear Fit" description="Enter the measurement required by each reviewed brand chart for an honest goalie-pad size result." canonicalPath="/calculator" {breadcrumbs}><Breadcrumbs items={breadcrumbs}/><header class="content"><p class="eyebrow">Dataset-backed sizing</p><h1>Goalie leg-pad size calculator</h1><p class="lede">Choose a brand and enter the exact measurement its reviewed chart uses. Your measurements stay in this browser.</p></header><div class="calculator-shell"><form id="calculator-form" class="calculator-form" novalidate><label>Brand<select id="brand"><option>Bauer</option><option>CCM</option><option>TRUE</option><option>Warrior</option><option>Brian's</option><option>Vaughn</option></select></label><fieldset><legend>Units</legend><label class="inline"><input type="radio" name="unit" value="in" checked> Inches</label><label class="inline"><input type="radio" name="unit" value="cm"> Centimetres</label></fieldset><label id="category-field">Age / level category<select id="category"><option value="">Choose category</option></select></label><label id="primary-field"><span id="primary-label">Floor to knee</span><input id="primary" type="number" min="0" step="0.01" inputmode="decimal" required><small>Use the method named by the chart.</small></label><label id="height-field">Standing height<input id="height" type="number" min="0" step="0.01" inputmode="decimal"></label><label id="ktt-field">Knee to thigh<input id="ktt" type="number" min="0" step="0.01" inputmode="decimal"></label><p id="form-error" class="error" role="alert"></p><button class="button" type="submit">Calculate chart size</button><p><a href="/guides/how-to-measure-goalie-pads">How to measure accurately</a></p></form><section id="result" class="result-card" tabindex="-1" aria-live="polite"><p class="eyebrow">Your result</p><h2 id="result-heading">Enter a measurement to begin</h2><div id="result-body"><p>The calculator will explain the reviewed chart match and the physical fit check to perform next.</p></div></section></div><section class="card" aria-labelledby="comparison-heading"><h2 id="comparison-heading">Cross-brand comparison</h2><p>Only brands using compatible measurements are calculated. Others explain what additional input is needed.</p><div id="comparison" class="comparison-list"><p>Complete a calculation to compare supported brands.</p></div></section><section class="card content"><h2>What the result means</h2><p>A recommendation is a chart match, not a guarantee of physical fit. Adjacent sizes mean ranges overlap. Conflict and cannot-determine states stop rather than guess.</p><p>Dataset {dataset.datasetId} v{dataset.version}, reviewed {dataset.reviewedAt}. <a href="/methodology">Read the methodology</a>.</p></section>
<script>
 import datasetJson from "../data/sizing/goalie-leg-pads-us-v0.1.json";import {recommend} from "../lib/engine/recommend";import type {Dataset} from "../lib/engine/types";import {brandInputs,buildInput,comparisonHtml,reasonCopy,statusHeading,supportedPreset,toInches} from "../lib/calculator/ui";import {analyticsEvents,failClosedReason,sendAnalytics} from "../lib/analytics";
 const form=document.querySelector<HTMLFormElement>("#calculator-form")!,brand=document.querySelector<HTMLSelectElement>("#brand")!,category=document.querySelector<HTMLSelectElement>("#category")!,primary=document.querySelector<HTMLInputElement>("#primary")!,height=document.querySelector<HTMLInputElement>("#height")!,ktt=document.querySelector<HTMLInputElement>("#ktt")!,result=document.querySelector<HTMLElement>("#result")!,heading=document.querySelector<HTMLElement>("#result-heading")!,body=document.querySelector<HTMLElement>("#result-body")!,error=document.querySelector<HTMLElement>("#form-error")!;
 const field=(id:string,show:boolean)=>{const el=document.querySelector<HTMLElement>(id)!;el.hidden=!show;el.querySelectorAll<HTMLInputElement|HTMLSelectElement>("input,select").forEach(x=>x.disabled=!show)};
 function configure(){const b=brand.value as keyof typeof brandInputs,c=brandInputs[b];document.querySelector("#primary-label")!.textContent=c.method==="floor_to_knee"?"Floor to knee":"Ankle to knee";field("#category-field",c.category);field("#height-field",c.height);field("#ktt-field",c.ktt);category.innerHTML='<option value="">Choose category</option>';for(const value of b==="Bauer"?["YOUTH","JUNIOR","INTERMEDIATE","SENIOR"]:b==="TRUE"?["JR","INT","SR"]:[])category.add(new Option(value,value));}
 brand.addEventListener("change",()=>{configure();sendAnalytics({name:analyticsEvents.brandSelected,props:{brand:brand.value}})});const preset=supportedPreset(new URLSearchParams(location.search).get("brand"));if(preset)brand.value=preset;configure();
 form.addEventListener("submit",event=>{event.preventDefault();error.textContent="";const raw=Number(primary.value);if(!Number.isFinite(raw)||raw<=0){error.textContent="Enter a measurement greater than zero.";primary.focus();return}const unit=(new FormData(form).get("unit")??"in") as "in"|"cm",convert=(el:HTMLInputElement)=>el.value?toInches(Number(el.value),unit):undefined;const input=buildInput(brand.value as keyof typeof brandInputs,{category:category.value||undefined,primary:toInches(raw,unit),height:convert(height),ktt:convert(ktt)});const out=recommend(datasetJson as Dataset,input);sendAnalytics({name:analyticsEvents.completed,props:{brand:brand.value,status:out.status}});if(["cannot_determine","conflict","extension_not_available"].includes(out.status))sendAnalytics({name:analyticsEvents.failClosed,props:{brand:brand.value,status:out.status,reason:failClosedReason(out.status,"reason" in out?out.reason:undefined)}});heading.textContent=statusHeading(out);const sizes=out.sizes.length?`<p class="result-size">${out.sizes.join(" or ")}</p>`:"",why=out.status==="cannot_determine"?reasonCopy[out.reason]:out.status==="conflict"?"The measurements point to disjoint reviewed chart rows.":"The measurements match the reviewed chart range.";body.innerHTML=`${sizes}<p>${why}</p>${out.matchedRuleIds.length?`<details><summary>Why this result</summary><p>Matched reviewed ${out.matchedRuleIds.length===1?"rule":"rules"}: ${out.matchedRuleIds.join(", ")}</p></details>`:""}<h3>Physical verification</h3><ul><li>Wear skates and knee protection.</li><li>Confirm the knee lands securely on the block.</li><li>Stop if rotation or thigh rise interferes.</li></ul>`;result.focus();});
 form.addEventListener("submit",()=>{const raw=Number(primary.value);if(!Number.isFinite(raw)||raw<=0)return;const unit=(new FormData(form).get("unit")??"in") as "in"|"cm",convert=(el:HTMLInputElement)=>el.value?toInches(Number(el.value),unit):undefined;document.querySelector<HTMLElement>("#comparison")!.innerHTML=comparisonHtml(datasetJson as Dataset,brand.value as keyof typeof brandInputs,{category:category.value||undefined,primary:toInches(raw,unit),height:convert(height),ktt:convert(ktt)});sendAnalytics({name:analyticsEvents.comparisonUsed,props:{brand:brand.value,status:"rendered"}});});
</script></BaseLayout>
