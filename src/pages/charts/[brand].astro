---
import BaseLayout from "../../layouts/BaseLayout.astro";
import Breadcrumbs from "../../components/content/Breadcrumbs.astro";
import SourceCitation from "../../components/content/SourceCitation.astro";
import SizeChart from "../../components/content/SizeChart.astro";
import {brandCopy} from "../../content/brand-copy";
import {getBrandCharts,type BrandChart} from "../../lib/content/brand-charts";
export function getStaticPaths(){return getBrandCharts().map(chart=>({params:{brand:chart.slug},props:{chart}}))}
interface Props{chart:BrandChart}
const {chart}=Astro.props; const copy=brandCopy[chart.slug];
const title=`${chart.brand} goalie pad size chart | Goalie Gear Fit`;
const description=`Reviewed ${chart.brand} goalie leg-pad sizing ranges and measurement guidance for the US market.`;
const breadcrumbs=[{label:"Home",href:"/"},{label:"Size charts",href:"/charts/"},{label:chart.brand}];
---
<BaseLayout {title} {description} canonicalPath={`/charts/${chart.slug}`} {breadcrumbs}><Breadcrumbs items={breadcrumbs}/><article><header class="content"><p class="eyebrow">US goalie leg pads</p><h1>{chart.brand} goalie pad size chart</h1><p class="lede">{copy.intro}</p><SourceCitation datasetId={chart.datasetId} version={chart.version} reviewedAt={chart.reviewedAt} market={chart.market}/>{"displayBadge" in chart.support&&<p class="badge">{chart.support.displayBadge}</p>}</header><section class="card" aria-labelledby="normalized-chart"><h2 id="normalized-chart">Normalized size chart</h2><p>Measurements below reproduce reviewed published rules in their source-native units.</p><SizeChart caption={`${chart.brand} goalie leg-pad sizing rules`} rows={chart.rules}/></section><section class="content card"><h2>How to read this {chart.brand} chart</h2><ul>{copy.howToRead.map(item=><li>{item}</li>)}</ul><aside class="warning"><h3>{copy.warningTitle}</h3><p>{copy.warning}</p></aside><span class="visually-hidden">{copy.marker}</span></section><section class="content card"><h2>Measure before choosing</h2><p>Use the measurement method named in the table. Different methods are not interchangeable.</p><p><a href="/guides/how-to-measure-goalie-pads">How to measure goalie pads</a> · <a href="/guides/thigh-rise-and-fit-check">Thigh rise and fit checks</a></p><p><a class="button" href={`/calculator?brand=${chart.slug}`}>Calculate for {chart.brand}</a></p></section><section class="content"><h2>Sources and fit safety</h2><p>Every row retains a reviewed source reference and rule id in the published dataset. Manufacturer charts are a starting point; model geometry, boot angle and stance still require an on-pad knee-block check.</p></section></article></BaseLayout>
